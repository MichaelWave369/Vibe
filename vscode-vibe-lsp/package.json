{
  "name": "vibe-lsp",
  "displayName": "Vibe Language Support",
  "description": "Minimal VS Code scaffold for the Vibe LSP",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:vibe"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "vibe",
        "aliases": ["Vibe", "vibe"],
        "extensions": [".vibe"],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
